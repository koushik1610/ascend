{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Edit(workspace/**)",
      "Write(workspace/**)",
      "WebSearch",
      "WebFetch",
      "Bash(python3 ui/server.py*)",
      "Bash(python3 tools/lint_artifacts.py*)",
      "Bash(mkdir -p workspace/*)",
      "Bash(mkdir workspace/*)",
      "Bash(rm -f workspace/*)",
      "Bash(git check-ignore*)",
      "Bash(pandoc workspace/*)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(nc *)",
      "Bash(ncat *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(sftp *)",
      "Bash(telnet *)",
      "Bash(bash -c *)",
      "Bash(sh -c *)",
      "Bash(zsh -c *)",
      "Bash(dash -c *)",
      "Bash(env *)",
      "Bash(xargs *)",
      "Bash(find * -exec*)",
      "Bash(find * -execdir*)",
      "Bash(node *)",
      "Bash(deno *)",
      "Bash(bun *)",
      "Bash(ruby *)",
      "Bash(perl *)",
      "Bash(php *)",
      "Bash(osascript *)",
      "Bash(python3 -c *)",
      "Bash(python -c *)",
      "Bash(eval *)",
      "Bash(exec *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.config/gh/**)",
      "Read(~/Library/Keychains/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.netrc)",
      "Read(**/.npmrc)",
      "Read(**/.git-credentials)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/*.pem)",
      "Edit(**/.env)",
      "Bash(pandoc * --lua-filter*)",
      "Bash(pandoc * --filter*)",
      "Bash(pandoc * -L *)",
      "Bash(pandoc -L*)",
      "Bash(pandoc --lua-filter*)",
      "Bash(pandoc --filter*)"
    ]
  }
}